{
  "manifest_version": 3,
  "name": "TabStack",
  "version": "1.11.8",
  "description": "TabStack - 浏览器工作会话管理器。保存当前窗口的标签页为可恢复的会话，随时一键找回。不再重复查找标签页，不再担心工作被中断。支持跨设备云同步、标签去重、智能搜索。",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://reccclnaxadbuccsrwmg.supabase.co; frame-src 'none'; base-uri 'self'; form-action 'self';"
  },
  "permissions": [
    "tabs",
    "storage",
    "unlimitedStorage",
    "notifications",
    "contextMenus",
    "alarms"
  ],
  "host_permissions": [
    "https://reccclnaxadbuccsrwmg.supabase.co/*"
  ],
  "action": {
    "default_icon": "icons/icon16.png",
    "default_title": "TabStack - 工作会话管理器"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png"
      ],
      "matches": [
        "chrome-extension://*/*"
      ]
    },
    {
      "resources": [
        "src/auth/*.html"
      ],
      "matches": [
        "https://reccclnaxadbuccsrwmg.supabase.co/*"
      ]
    }
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open tab manager"
    },
    "save_all_tabs": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Save all tabs"
    },
    "save_current_tab": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Save current tab"
    }
  }
}
