{
  "name": "chrome-plugin-one-tab",
  "version": "1.13.3",
  "description": "保存浏览器工作会话，稍后快速找回与恢复",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:dev": "tsc && vite build",
    "package": "pnpm build && node package-extension.js",
    "preview": "vite preview",
    "test": "node --test --test-force-exit --experimental-strip-types --experimental-test-module-mocks tests/*.test.ts",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit",
    "validate": "node scripts/validate-extension.mjs && pnpm type-check && pnpm lint && pnpm build",
    "verify": "pnpm validate && pnpm test",
    "audit:fix": "node scripts/check-audit.mjs",
    "test:supabase-smoke": "node scripts/supabase-smoke-test.mjs"
  },
  "keywords": [
    "chrome-extension",
    "tab-management",
    "react",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.1",
    "@supabase/supabase-js": "^2.75.1",
    "@types/lodash": "^4.17.16",
    "clsx": "^2.1.1",
    "lodash": "^4.18.1",
    "lz-string": "^1.5.0",
    "react": "^18.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "react-redux": "^9.1.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.21",
    "@types/chrome": "^0.0.262",
    "@types/lz-string": "^1.5.0",
    "@types/node": "^22.14.0",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "fake-indexeddb": "^6.2.5",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2",
    "vite": "^4.5.14"
  }
}
